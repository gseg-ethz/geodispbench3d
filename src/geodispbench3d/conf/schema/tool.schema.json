{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geodispbench3d/schema/tool.json",
  "title": "geodispbench3d tool config",
  "type": "object",
  "required": ["id", "kind", "entry"],
  "properties": {
    "id": {"type": "string"},
    "kind": {"enum": ["cli", "python_callable", "callable", "custom", "factory"]},
    "entry": {"type": "string"},
    "execution": {
      "type": "object",
      "properties": {
        "mode": {"enum": ["subprocess", "in_process"], "default": "subprocess"},
        "in_process_safe": {"type": "boolean", "default": false},
        "timeout_seconds": {
          "type": "number",
          "description": "Optional per-trial wall-clock timeout (seconds). Unset or <= 0 disables the timeout. On expiry the tool process tree is killed and the trial is recorded as a timeout failure."
        }
      }
    },
    "invocation": {
      "type": "object",
      "properties": {
        "style": {"enum": ["hydra_overrides", "argparse", "kv_equals"]},
        "extra_args": {"type": "array", "items": {"type": "string"}}
      }
    },
    "hyperparameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"enum": ["choice", "range", "fixed"]},
          "value_type": {"enum": ["str", "int", "float", "bool"]},
          "values": {"type": "array"},
          "lower": {"type": "number"},
          "upper": {"type": "number"},
          "log_scale": {"type": "boolean"},
          "step": {"type": "number"},
          "activates_on": {"type": "object"},
          "is_ordered": {"type": "boolean"},
          "sort_values": {"type": "boolean"}
        }
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "from": {
          "enum": ["glob", "stdout_json"],
          "default": "glob",
          "description": "Output-collection mode. 'glob' is the single blessed path (default when unset). 'stdout_json' is deprecated and rejected at load — migrate to 'glob' with a predictions_glob."
        },
        "run_dir_root": {"type": "string"},
        "predictions_glob": {"type": "string"},
        "figures_glob": {"type": "string"}
      }
    }
  }
}
